# =============================================================================
# Environment Configuration File
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit your .env file to Git! It contains secrets.
# The .gitignore file already excludes .env files.
# =============================================================================

# --- REQUIRED ---
# Your Google Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY="your_api_key_here"

# --- OPTIONAL: Embedding Configuration ---
# Set to "true" to use local HuggingFace embeddings (free but slower)
# Set to "false" (default) to use Gemini API embeddings (faster, uses quota)
# USE_LOCAL_EMBEDDINGS="false"

# The HuggingFace model for local embeddings
# LOCAL_MODEL_NAME="all-MiniLM-L6-v2"

# The Gemini model for API-based embeddings
# API_MODEL_NAME="models/gemini-embedding-001"

# --- OPTIONAL: Generation Model ---
# The Gemini model for generating answers
# GENERATION_MODEL="models/gemini-2.0-flash"
